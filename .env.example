# ─────────────────────────────────────────────────────────
# TrustMesh MCP Server — Environment Configuration
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to source control.

# ── Server ───────────────────────────────────────────────
# Runtime environment (development | production)
NODE_ENV=development

# Log verbosity (debug | info | warn | error)
LOG_LEVEL=info

# ── Risk Engine Thresholds ────────────────────────────────
# Composite risk score >= this value triggers a hard block (RBI MRM §4.5)
RISK_BLOCK_THRESHOLD=75

# Composite risk score >= this value routes transaction to HITL review queue
RISK_REVIEW_THRESHOLD=50

# ── Nitrostack Deployment ─────────────────────────────────
# Your Nitrostack API key (obtain from studio.nitrostack.ai)
NITROSTACK_API_KEY=your_nitrostack_api_key_here

# Cloud deployment region (ap-south-1 = Mumbai, recommended for RBI compliance)
NITROSTACK_REGION=ap-south-1

# ── External Data Sources ─────────────────────────────────
# Exchange rate API (open.er-api.com — free tier, no key required)
# Set to 'false' to disable live FX and always use fallback static rates
ENABLE_LIVE_FX_RATES=true

# Yahoo Finance market data (unofficial endpoint — no key required)
# Set to 'false' to always serve curated static BFSI data (good for offline demos)
ENABLE_LIVE_MARKET_DATA=true

# Market data cache TTL in milliseconds (default: 5 minutes)
MARKET_DATA_CACHE_MS=300000

# ── Key Store ─────────────────────────────────────────────
# Path to key store data directory (relative to process.cwd())
# Default: src/data  (development)  |  /app/data  (production)
DATA_DIRECTORY=src/data
